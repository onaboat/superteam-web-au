# Supabase — create a project at https://supabase.com and run SQL from supabase/migrations/
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Anon key (same value Supabase may label "publishable" in the dashboard)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional alias — use only if you prefer the dashboard name (do not set both to different values)
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""

# Server only — never expose to the browser (used for Get Involved inserts)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional — only for `npm run db:migrate` (Postgres URI from Dashboard → Database)
# Not the anon/publishable key. Never commit this file with a real password.
# Prefer "Transaction" pooler (port 6543) if you see EHOSTUNREACH / IPv6 errors on the direct host.
# SUPABASE_DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# Existing (Sanity, etc.)
# NEXT_PUBLIC_SANITY_...
